<Window x:Class="ConSight.DONGBO.PlcSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC Simulator  —  localhost:5000" Height="620" Width="900"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Trigger buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnTriggerOp200" Content="OP200 Trigger" Width="130" Height="36"
                    Margin="0,0,8,0" Click="BtnTriggerOp200_Click"/>
            <Button x:Name="BtnTriggerOp210" Content="OP210 Trigger" Width="130" Height="36"
                    Margin="0,0,8,0" Click="BtnTriggerOp210_Click"/>
            <Button x:Name="BtnTriggerOp220" Content="OP220 Trigger" Width="130" Height="36"
                    Margin="0,0,8,0" Click="BtnTriggerOp220_Click"/>
            <Button x:Name="BtnTriggerOp230" Content="OP230 Trigger" Width="130" Height="36"
                    Click="BtnTriggerOp230_Click"/>
        </StackPanel>

        <!-- Memory snapshot -->
        <GroupBox Grid.Row="1" Header="PLC Memory Snapshot">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="4,2">
                    <TextBlock Text="OP200  D2000" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxOp200Snap" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="4,2">
                    <TextBlock Text="OP210  D2200" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxOp210Snap" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="4,2">
                    <TextBlock Text="OP220  D2300" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxOp220Snap" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="4,2">
                    <TextBlock Text="OP230  D2400" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock x:Name="TxOp230Snap" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Communication log -->
        <GroupBox Grid.Row="2" Header="Communication Log" Margin="0,8,0,0">
            <TextBox x:Name="TxLog" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11"
                     TextWrapping="Wrap"/>
        </GroupBox>
    </Grid>
</Window>
